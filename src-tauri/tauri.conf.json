{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mxtools",
  "version": "0.0.2",
  "identifier": "online.0w0.mxtools",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "萌新工具箱",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "file_capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
